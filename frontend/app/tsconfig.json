{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@claw/core": ["../packages/claw-core/src/index.ts"],
      "@claw/ui": ["../packages/claw-ui/src/index.ts"]
    },
    "types": ["vite/client"]
  },
  "include": ["src"]
}
