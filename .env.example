# LLM Configuration
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=your_model_name
LLM_API_KEY=
# LLM_TIMEOUT_S=120
# LLM_DEFAULT_TEMPERATURE=0.7
# LLM_SUPPORTS_VISION=false          # Enable multimodal (requires vision-capable model)
# LLM_ENABLE_THINKING=false          # Enable <think> tag parsing

# Agent Runtime
# AGENT_MAX_ITERATIONS=25            # ReAct loop max iterations
# AGENT_MODEL_CONTEXT_WINDOW=32000   # Model context window size
# AGENT_MAX_TOOL_RESULT_CHARS=3000   # Tool result truncation limit

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
# APP_DEBUG=false
# CORS_ALLOWED_ORIGINS=*             # Comma-separated, '*' for all

# Auth (default: disabled for dev)
AUTH_ENABLED=false
AUTH_MODE=jwt                         # jwt | api_key
AUTH_JWT_SECRET=                      # Required when AUTH_ENABLED=true
AUTH_DEFAULT_TENANT_ID=default
AUTH_DEFAULT_USER_ID=U001

# Database
DB_PATH=data/claw.db

# MCP (optional)
# MCP_ENABLED=false                  # Enable MCP standard tools
# MCP_BASE_URL=                      # MCP HTTP provider URL (empty = DefaultMCPProvider)

# Scheduler (A9)
# SCHEDULER_ENABLED=true             # Enable cron scheduler
# SCHEDULER_TIMEZONE=Asia/Shanghai   # Timezone for cron interpretation

# Webhook (A9)
# WEBHOOK_TIMEOUT_S=10.0
# WEBHOOK_MAX_RETRIES=3

# Security Sandbox (A6)
# SANDBOX_MAX_DISK_QUOTA_MB=500      # Per-user disk quota
# SANDBOX_BLOCK_PRIVATE_NETWORKS=true
# SANDBOX_RATE_LIMIT_PER_MINUTE=100

# Files
# MAX_FILE_UPLOAD_MB=100
# FILE_RETENTION_DAYS=7              # Session file retention (0 = keep forever)

# Logging
# LOG_LEVEL=INFO
# LOG_FORMAT=console                  # console | json
