# LLM Configuration
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5
LLM_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000

# Auth (default: disabled for dev)
AUTH_ENABLED=false
AUTH_MODE=jwt
AUTH_JWT_SECRET=
AUTH_DEFAULT_TENANT_ID=default
AUTH_DEFAULT_USER_ID=U001
AUTH_API_KEYS=

# OIDC (auth_mode=oidc)
AUTH_OIDC_ISSUER=
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=
AUTH_OIDC_REDIRECT_URI=http://localhost:8000/api/auth/callback/oidc
AUTH_OIDC_TENANT_CLAIM=org_id
AUTH_OIDC_USER_CLAIM=sub

# SAML (auth_mode=saml)
AUTH_SAML_IDP_METADATA_URL=
AUTH_SAML_SP_ENTITY_ID=claw-for-saas
AUTH_SAML_SP_ACS_URL=http://localhost:8000/api/auth/callback/saml
AUTH_SAML_TENANT_ATTR=org_id
AUTH_SAML_USER_ATTR=uid
